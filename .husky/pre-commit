#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

export LC_ALL=en_US.UTF-8
export LANG=pt_BR.UTF-8
RED=$(tput setaf 1)
GREEN=$(tput setaf 2)
RESET=$(tput sgr0)

echo "🚀 Preparing to commit changes..."
echo "----------------------------------"

echo "🎨 Checking C# file formatting with CSharpier..."
if dotnet csharpier . --check; then
    echo "✅ All files are properly formatted."
else
    echo "❌ Some files need formatting. Formatting now..."
    dotnet csharpier .
    echo "✅ Files formatted successfully. Adding to commit..."
    git add .
fi

echo "🛠️ Running format check on staged files..."
dotnet husky run --name dotnet-format-csharpier || {
    echo "❌ Format checks failed. Please fix the issues and try again."
    exit 1
}

# Get current branch name
current_branch=$(git symbolic-ref --short HEAD)

# Check if this is a git flow finish operation
is_finish=$(git reflog -1 | grep -q "finish" && echo "yes" || echo "no")

if [ "$is_finish" = "yes" ]; then
    echo "🔍 Detected git flow finish operation"
    echo "Current branch: $current_branch"

    # Function to get PR body
    get_pr_body() {
        default_body=$1
        echo "💬 Enter PR body (press CTRL+D when finished, or ENTER to use default):"
        echo "Default body: $default_body"
        echo "-------------------"
        NEW_BODY=$(cat)
        
        if [ -z "$NEW_BODY" ]; then
            echo "$default_body"
        else
            echo "$NEW_BODY"
        fi
    }

    case "$current_branch" in
      feature/*)
        PR_TITLE="Feature completed: ${current_branch#feature/}"
        DEFAULT_BODY="This feature is ready for review."
        PR_BODY=$(get_pr_body "$DEFAULT_BODY")
        BASE_BRANCH="dev"
        ;;
      hotfix/*)
        PR_TITLE="Hotfix: ${current_branch#hotfix/}"
        DEFAULT_BODY="Urgent hotfix for production."
        PR_BODY=$(get_pr_body "$DEFAULT_BODY")
        BASE_BRANCH="main"
        
        # Create PR for dev
        echo "📝 Creating additional PR for dev..."
        gh pr create \
          --title "$PR_TITLE" \
          --body "$PR_BODY" \
          --base "dev" \
          --head "$current_branch" || true
        ;;
      bugfix/*)
        PR_TITLE="Bugfix: ${current_branch#bugfix/}"
        DEFAULT_BODY="Bug fixed and ready for review."
        PR_BODY=$(get_pr_body "$DEFAULT_BODY")
        BASE_BRANCH="dev"
        ;;
      release/*)
        PR_TITLE="Release: ${current_branch#release/}"
        DEFAULT_BODY="Release is ready for production."
        PR_BODY=$(get_pr_body "$DEFAULT_BODY")
        BASE_BRANCH="main"
        
        # Create PR for dev
        echo "📝 Creating additional PR for dev..."
        gh pr create \
          --title "$PR_TITLE" \
          --body "$PR_BODY" \
          --base "dev" \
          --head "$current_branch" || true
        ;;
      *)
        echo "⚠️ Branch $current_branch does not match any configured case. Ignoring."
        exit 0
        ;;
    esac

    echo "📝 Creating Pull Request..."
    echo "Title: $PR_TITLE"
    echo "Body: $PR_BODY"
    echo "Base branch: $BASE_BRANCH"
    echo "Source branch: $current_branch"

    git push origin "$current_branch" || true

    gh pr create \
      --title "$PR_TITLE" \
      --body "$PR_BODY" \
      --base "$BASE_BRANCH" \
      --head "$current_branch" || true
fi

echo "----------------------------------"
echo "✅ Pre-commit checks completed successfully."
#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

current_branch=$(git rev-parse --abbrev-ref HEAD)
previous_branch=$(git reflog -1 | grep -o 'from.*' | cut -d' ' -f2 | sed 's/:$//')

echo "🔍 Current branch: $current_branch"
echo "🔍 Previous branch: $previous_branch"

get_pr_body() {
    default_body=$1
    echo "💬 Enter PR body (press CTRL+D when finished, or ENTER to use default):"
    echo "Default body: $default_body"
    echo "-------------------"
    NEW_BODY=$(cat)
    
    if [ -z "$NEW_BODY" ]; then
        echo "$default_body"
    else
        echo "$NEW_BODY"
    fi
}

case "$previous_branch" in
  feature/*)
    PR_TITLE="Feature completed: ${previous_branch#feature/}"
    DEFAULT_BODY="This feature is ready for review."
    PR_BODY=$(get_pr_body "$DEFAULT_BODY")
    BASE_BRANCH="dev"
    SOURCE_BRANCH="$previous_branch"
    ;;
  hotfix/*)
    PR_TITLE="Hotfix: ${previous_branch#hotfix/}"
    DEFAULT_BODY="Urgent hotfix for production."
    PR_BODY=$(get_pr_body "$DEFAULT_BODY")
    BASE_BRANCH="main"
    SOURCE_BRANCH="$previous_branch"
    
    echo "📝 Creating additional PR for dev..."
    gh pr create \
      --title "$PR_TITLE" \
      --body "$PR_BODY" \
      --base "dev" \
      --head "$SOURCE_BRANCH" || true
    ;;
  bugfix/*)
    PR_TITLE="Bugfix: ${previous_branch#bugfix/}"
    DEFAULT_BODY="Bug fixed and ready for review."
    PR_BODY=$(get_pr_body "$DEFAULT_BODY")
    BASE_BRANCH="dev"
    SOURCE_BRANCH="$previous_branch"
    ;;
  release/*)
    PR_TITLE="Release: ${previous_branch#release/}"
    DEFAULT_BODY="Release is ready for production."
    PR_BODY=$(get_pr_body "$DEFAULT_BODY")
    BASE_BRANCH="main"
    SOURCE_BRANCH="$previous_branch"
    
    echo "📝 Creating additional PR for dev..."
    gh pr create \
      --title "$PR_TITLE" \
      --body "$PR_BODY" \
      --base "dev" \
      --head "$SOURCE_BRANCH" || true
    ;;
  *)
    echo "⚠️ Branch $previous_branch does not match any configured case. Ignoring."
    exit 0
    ;;
esac

echo "📝 Creating Pull Request..."
echo "Title: $PR_TITLE"
echo "Body: $PR_BODY"
echo "Base branch: $BASE_BRANCH"
echo "Source branch: $SOURCE_BRANCH"

gh pr create \
  --title "$PR_TITLE" \
  --body "$PR_BODY" \
  --base "$BASE_BRANCH" \
  --head "$SOURCE_BRANCH" || true
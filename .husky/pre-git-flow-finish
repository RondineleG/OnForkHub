#!/bin/sh
. "$(dirname "$0")/_/husky.sh"

current_branch=$(git symbolic-ref --short HEAD)
echo "📎 Current branch: $current_branch"

get_pr_body() {
    default_body=$1
    echo "💬 Enter PR body (press CTRL+D when finished, or ENTER to use default):"
    echo "Default body: $default_body"
    echo "-------------------"
    NEW_BODY=$(cat)
    
    if [ -z "$NEW_BODY" ]; then
        echo "$default_body"
    else
        echo "$NEW_BODY"
    fi
}

case "$current_branch" in
  feature/*)
    PR_TITLE="Feature completed: ${current_branch#feature/}"
    DEFAULT_BODY="This feature is ready for review."
    PR_BODY=$(get_pr_body "$DEFAULT_BODY")
    BASE_BRANCH="dev"
    ;;
  hotfix/*)
    PR_TITLE="Hotfix: ${current_branch#hotfix/}"
    DEFAULT_BODY="Urgent hotfix for production."
    PR_BODY=$(get_pr_body "$DEFAULT_BODY")
    
    echo "📝 Creating Pull Request for main..."
    gh pr create \
      --title "$PR_TITLE" \
      --body "$PR_BODY" \
      --base "main" \
      --head "$current_branch"
    
    echo "📝 Creating Pull Request for dev..."
    gh pr create \
      --title "$PR_TITLE" \
      --body "$PR_BODY" \
      --base "dev" \
      --head "$current_branch"
    
    exit 0
    ;;
  bugfix/*)
    PR_TITLE="Bugfix: ${current_branch#bugfix/}"
    DEFAULT_BODY="Bug fixed and ready for review."
    PR_BODY=$(get_pr_body "$DEFAULT_BODY")
    BASE_BRANCH="dev"
    ;;
  release/*)
    PR_TITLE="Release: ${current_branch#release/}"
    DEFAULT_BODY="Release is ready for production."
    PR_BODY=$(get_pr_body "$DEFAULT_BODY")
    
    echo "📝 Creating Pull Request for main..."
    gh pr create \
      --title "$PR_TITLE" \
      --body "$PR_BODY" \
      --base "main" \
      --head "$current_branch"
    
    echo "📝 Creating Pull Request for dev..."
    gh pr create \
      --title "$PR_TITLE" \
      --body "$PR_BODY" \
      --base "dev" \
      --head "$current_branch"
    
    exit 0
    ;;
  *)
    echo "⚠️ Branch $current_branch does not match any configured case. Ignoring."
    exit 0
    ;;
esac

if [[ "$current_branch" =~ ^(feature|bugfix)/ ]]; then
    echo "📝 Creating Pull Request..."
    echo "Title: $PR_TITLE"
    echo "Body: $PR_BODY"
    echo "Base branch: $BASE_BRANCH"
    echo "Source branch: $current_branch"

    gh pr create \
      --title "$PR_TITLE" \
      --body "$PR_BODY" \
      --base "$BASE_BRANCH" \
      --head "$current_branch"

    if [[ $? -eq 0 ]]; then
        echo "✅ Pull Request created successfully!"
    else
        echo "❌ Error creating Pull Request. Trying to debug..."
        echo "Current repository: $(git remote get-url origin)"
        echo "Available branches:"
        git branch -a
    fi
fi
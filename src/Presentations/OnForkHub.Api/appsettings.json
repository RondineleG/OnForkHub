{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "ConnectionStrings": {
        "DefaultConnection": "Data Source=localhost;Initial Catalog=OnForkHub;trusted_connection=true;TrustServerCertificate=True;"
    },
    "RavenDbSettings": {
        "Urls": [ "http://localhost:8080" ],
        "Database": "OnForkHub"
    },
    "AppSettings": {
        "ApiMode": "Rest"
    },
    "Jwt": {
        "SecretKey": "CHANGE_THIS_TO_A_SECURE_SECRET_KEY_AT_LEAST_32_CHARS",
        "Issuer": "OnForkHub.Api",
        "Audience": "OnForkHub.Client",
        "ValidateIssuer": true,
        "ValidateAudience": true,
        "ValidateLifetime": true,
        "ValidateIssuerSigningKey": true,
        "AccessTokenExpirationMinutes": 60,
        "RefreshTokenExpirationDays": 7
    },
    "Cors": {
        "AllowedOrigins": [ "http://localhost:5000", "https://localhost:5001" ]
    },
    "Cache": {
        "UseRedis": false,
        "RedisConnectionString": "",
        "InstanceName": "OnForkHub_",
        "DefaultExpirationMinutes": 30
    },
    "RateLimiting": {
        "Enabled": true,
        "PermitLimit": 100,
        "WindowSeconds": 60,
        "QueueLimit": 10,
        "AuthenticatedPermitLimit": 500,
        "AnonymousPermitLimit": 50,
        "AuthPermitLimitPerMinute": 10
    }
}

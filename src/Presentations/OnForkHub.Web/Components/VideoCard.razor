@if (Video is not null)
{
    <div class="hc-wrapper">
        <div class="hc-card @(NowPlayingVideo == Video.Title ? "selected" : "")"
             @onclick="playVideo">
            <div class="hc-content">
                <picture>
                    <img src="@(string.IsNullOrEmpty(Video.Thumbnail) ? "/images/video-placeholder.png" : Video.Thumbnail)" alt="@Video.Title"/>
                </picture>
                <div class="p-2">
                    <p class="text-center mb-1 fw-bold text-truncate">
                        @Video.Title
                    </p>
                    <div class="d-flex justify-content-between smaller text-muted px-2">
                        <span>@FormatViews(Video.ViewCount) views</span>
                        <span>@Video.CreatedAt.ToShortDateString()</span>
                    </div>
                </div>
                <button type="button" class="btn btn-glass">
                    @if (NowPlayingVideo == Video.Title)
                    {
                        <i class="bi bi-pause"></i>
                    }
                    else
                    {
                        <i class="bi bi-play"></i>
                    }
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] [EditorRequired] public Video? Video { get; set; }

    [Parameter] public string? NowPlayingVideo { get; set; }

    [Parameter] public EventCallback OnPlayCallBack { get; set; }

    [Parameter] public EventCallback OnStopCallBack { get; set; }

    private async Task playVideo()
    {
        await OnPlayCallBack.InvokeAsync();
    }

    private async Task stopVideo()
    {
        await OnStopCallBack.InvokeAsync();
    }

    private string FormatViews(long views)
    {
        if (views < 1000) return views.ToString();
        if (views < 1000000) return $"{(views / 1000.0):F1}K";
        return $"{(views / 1000000.0):F1}M";
    }
}

@page "/embed/{Id}"
@layout OnForkHub.Web.Shared.EmbedLayout
@attribute [AllowAnonymous]
@inject IVideoService VideoService
@inject NavigationManager Navigation

<PageTitle>Embed - OnForkHub</PageTitle>

@if (video != null)
{
    <HeadContent>
        <meta name="robots" content="noindex" />
    </HeadContent>
}

<div class="embed-player-wrapper bg-black position-fixed top-0 start-0 w-100 h-100">
    @if (isLoading)
    {
        <div class="d-flex justify-content-center align-items-center h-100">
            <div class="spinner-border text-primary" role="status"></div>
        </div>
    }
    else if (video == null)
    {
        <div class="d-flex justify-content-center align-items-center h-100 text-white">
            <p>Vídeo não encontrado.</p>
        </div>
    }
    else
    {
        <AdaptiveVideoPlayer ManifestUrl="@($"/api/v1/videos/{video.Id}/stream/manifest.mpd")" AutoPlay="false" />
        
        <div class="embed-overlay position-absolute bottom-0 end-0 p-2">
            <a href="/video/@video.Id" target="_blank" class="text-white opacity-75 text-decoration-none small">
                Assistir no OnForkHub <i class="bi bi-box-arrow-up-right"></i>
            </a>
        </div>
    }
</div>

@code {
    [Parameter] public string Id { get; set; } = string.Empty;

    private OnForkHub.Web.Models.Video? video;
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            isLoading = true;
            video = await VideoService.GetVideoByIdAsync(Id);
        }
        catch
        {
            video = null;
        }
        finally
        {
            isLoading = false;
        }
    }
}
